# WatchNode Agent - Example Configuration
# Copy to /etc/watchnode/agent/config.yaml or use --config

agent:
  id: ""  # Auto-generated if empty
  name: "{{hostname}}"
  labels:
    environment: production
    region: us-east
    team: security
    _enroll_token: "REPLACE_WITH_YOUR_ENROLL_TOKEN"  # Must match WATCHTOWER_GRPC_ENROLL_TOKEN

manager:
  url: "127.0.0.1:50051"
  tls:
    cert: "scripts/certs/client.crt"
    key: "scripts/certs/client.key"
    ca: "scripts/certs/ca.crt"
  reconnect:
    max_attempts: 0
    initial_backoff: "1s"
    max_backoff: "5m"

collectors:
  system:
    enabled: true
    interval: "30s"
    metrics:
      - cpu
      - memory
      - disk
      - network
      - processes

  file_integrity:
    enabled: true
    interval: "5m"
    paths:
      - path: "/etc"
        recursive: true
        ignore_patterns: ["*.lock", "*.pid"]
      - path: "/usr/bin"
        recursive: true
    hash_algorithms: ["sha256"]
    scan_on_start: true

  logs:
    enabled: true
    sources:
      - type: file
        path: "/var/log/auth.log"
        tags: [authentication]
        multiline_pattern: "^\\d{4}-\\d{2}-\\d{2}"
      - type: journal
        units: ["sshd", "systemd-logind", "sudo"]
      - type: eventlog
        channels: ["Security", "Application", "System"]
    max_line_length: 1048576
    max_buffer_size: 10485760

  process:
    enabled: true
    interval: "30s"

  network:
    enabled: true
    interval: "30s"

  sca:
    enabled: true
    interval: "12h"
    policy_dirs:
      - "/etc/watchnode/sca/policies"
      - "configs/sca"
    # Available policies in configs/sca/:
    #   cis_windows_server_2022.yaml  — CIS Windows Server 2022 benchmark
    #   cis_ubuntu_linux_22_04.yaml   — CIS Ubuntu 22.04 benchmark
    #   pci_dss_v4_windows.yaml       — PCI DSS v4.0
    #   hipaa_windows.yaml            — HIPAA Security Rule
    #   nist_800_53_windows.yaml      — NIST SP 800-53 Rev 5
    #   gdpr_windows.yaml             — GDPR Article 32

  vulnerability:
    enabled: false
    interval: "24h"
    db_path: "/var/lib/watchnode/vulndb"
    db_update_url: "https://vulndb.watchnode.io/latest"

  syscollector:
    enabled: true
    interval: "1h"
    hardware: true
    os: true
    packages: true
    ports: true
    network_interfaces: true
    users: true
    services: true    # Windows/Linux service inventory
    hotfixes: true    # Windows patch/hotfix status

performance:
  max_cpu_percent: 20
  max_memory_bytes: 268435456
  max_disk_bytes: 1073741824
  batch_size: 1000
  flush_interval: "30s"
  queue_size: 10000

# Automatic agent binary updates.
# When enabled, the agent checks the update server for a newer release on the
# configured interval.  If a new version is found, the binary is downloaded,
# its SHA-256 is verified, and the agent restarts in-place.
autoupdate:
  enabled: false
  update_server_url: "https://updates.watchnode.io"
  check_interval: "24h"
  allow_prerelease: false
