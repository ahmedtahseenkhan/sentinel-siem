# WatchTower (Manager) REST API — Bearer API-key auth (Docker: use service name + port 9400)
WATCHTOWER_URL=http://localhost:9400
WATCHTOWER_API_KEY=REPLACE_WITH_WATCHTOWER_API_KEY

# WatchVault (Indexer) REST API — Bearer API-key auth (Docker: use service name + port 9500)
WATCHVAULT_URL=http://localhost:9500
WATCHVAULT_API_KEY=REPLACE_WITH_WATCHVAULT_API_KEY

# OpenSearch — direct index queries, HTTP Basic auth (default admin/admin in dev)
# Using https:// against a plain-HTTP indexer causes: SSLEOFError / UNEXPECTED_EOF_WHILE_READING
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Index prefix used by WatchVault: indices are <prefix>-<type>-<date>
INDEX_PREFIX=watchvault

# Set to true only if you use valid SSL certificates
VERIFY_SSL=false

# API request timeout in seconds
REQUEST_TIMEOUT=15

# Dashboard login (Phase 6.3: super_admin, administrator, security_analyst, compliance_officer)
# Set SECRET_KEY to a random string in production (used for session cookies).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX
DASHBOARD_SUPER_ADMIN_USER=superadmin
DASHBOARD_SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Optional: multiple users with roles (user:password:role). Roles: super_admin, administrator, security_analyst, compliance_officer
# DASHBOARD_USERS=superadmin:secret:super_admin,analyst:secret:security_analyst,compliance:secret:compliance_officer

# ── Ticketing ───────────────────────────────────────────────────────────────
# Ticketing is built-in (native) — tickets are WatchTower cases with priority,
# SLA, auto-assignment, status workflow, comments, and audit. No external ITSM
# or credentials required, nothing to configure here.
