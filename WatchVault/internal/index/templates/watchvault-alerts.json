{
  "index_patterns": ["watchvault-alerts-*"],
  "template": {
    "settings": {
      "number_of_shards": 2,
      "number_of_replicas": 1,
      "index.refresh_interval": "10s",
      "plugins.index_state_management.policy_id": "watchvault-alerts-policy"
    },
    "mappings": {
      "date_detection": false,
      "dynamic_templates": [
        {
          "strings_as_keyword": {
            "match_mapping_type": "string",
            "mapping": {"type": "keyword", "ignore_above": 8192}
          }
        }
      ],
      "properties": {
        "timestamp": {"type": "date", "format": "epoch_millis"},
        "rule_id": {"type": "integer"},
        "rule_level": {"type": "integer"},
        "rule_description": {"type": "text", "fields": {"keyword": {"type": "keyword"}}},
        "rule_groups": {"type": "keyword"},
        "agent_id": {"type": "keyword"},
        "agent_name": {"type": "keyword"},
        "title": {"type": "text", "fields": {"keyword": {"type": "keyword"}}},
        "event_type": {"type": "keyword"},
        "event_data": {"type": "object", "dynamic": true},
        "tags": {"type": "object", "dynamic": true}
      }
    }
  }
}
