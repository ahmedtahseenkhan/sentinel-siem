# ── Secrets & credentials ────────────────────────────────────────────────────
.env
*.env
.env.*
!.env.example
!*.env.example

# Private keys and certificate authority keys
*.key
*.pem
!*.pub

# Generated certificates (never commit private keys or signing requests)
scripts/certs/ca.key
scripts/certs/server.key
scripts/certs/client.key
WatchNode/scripts/certs/*.key
WatchTower/scripts/certs/*.key
WatchVault/scripts/certs/*.key
# Certificate signing requests — intermediate artifacts, regenerated by openssl
*.csr

# ── Go build outputs ────────────────────────────────────────────────────────
# Compiled binaries (use explicit paths to avoid matching directories on case-insensitive FS)
WatchNode/cmd/agent/watchnode
WatchNode/cmd/agent/watchnode.exe
WatchNode/cmd/agent/watchnode-linux
WatchNode/watchnode
WatchNode/watchnode-manager
WatchNode/winsim
WatchNode/sentinel-agent
WatchNode/sentinel-manager
WatchTower/cmd/watchtower/watchtower
WatchTower/watchtower
WatchVault/cmd/watchvault/watchvault
WatchVault/watchvault
*.test
*.out
/bin/
/dist/
/build/

# Go module cache
vendor/

# ── IDE / OS ────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ── Runtime data ─────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
/data/
/logs/
/tmp/

# ── Python (corenestDashboard) ───────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
# Match any virtualenv directory name (venv, venv312, venv3.12, .venv, etc.)
venv*/
.venv*/
**/venv*/
*.egg-info/

# ── Node / Next.js (marketing) ───────────────────────────────────────────────
node_modules/
marketing/.next/
marketing/out/
.next/

# ── mTLS certificates (never commit private keys) ────────────────────────────
certs/*.key
certs/*.crt
certs/*.srl

# Built agent artifacts — regenerate with scripts/build-agent-package.sh
WatchNode/SentinelAgent.zip
WatchNode/SentinelAgent/watchnode.exe
WatchNode/cmd/agent/watchnode-linux
