# Sentinel Manager API (Docker: use host or service name and port 55000)
# 401 Unauthorized? Use the SAME username/password as your Sentinel / Wazuh stack:
#   - Docker: copy API_USERNAME / API_PASSWORD from your Sentinel/Wazuh docker-compose or .env
#   - Install script: see wazuh-install-files/wazuh-passwords.txt
#   - Or use the login you use for the Sentinel Manager UI
SENTINEL_MANAGER_URL=https://localhost:55000
SENTINEL_MANAGER_USER=wazuh
SENTINEL_MANAGER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Sentinel Indexer (Docker: use http://localhost:9200 unless TLS is enabled on 9200)
# Using https:// against a plain-HTTP indexer causes: SSLEOFError / UNEXPECTED_EOF_WHILE_READING
SENTINEL_INDEXER_URL=http://localhost:9200
SENTINEL_INDEXER_USER=admin
SENTINEL_INDEXER_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Set to true only if you use valid SSL certificates
VERIFY_SSL=false

# API request timeout in seconds (Manager and Indexer)
REQUEST_TIMEOUT=15

# Dashboard login (Phase 6.3: super_admin, administrator, security_analyst, compliance_officer)
# Set SECRET_KEY to a random string in production (used for session cookies).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_HEX
DASHBOARD_SUPER_ADMIN_USER=superadmin
DASHBOARD_SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# Optional: multiple users with roles (user:password:role). Roles: super_admin, administrator, security_analyst, compliance_officer
# DASHBOARD_USERS=superadmin:secret:super_admin,analyst:secret:security_analyst,compliance:secret:compliance_officer
