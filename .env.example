# Sentinel SIEM — Environment Configuration
# Copy this file to .env and replace ALL placeholder values before running in production.
# DO NOT commit .env to version control.

# ── WatchTower (Manager) ──────────────────────────────────────────────────────
# REST API authentication key — used by dashboard + external clients
WATCHTOWER_API_KEY=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# gRPC enrollment token — agents must present this when registering
WATCHTOWER_GRPC_ENROLL_TOKEN=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# ── WatchVault (Indexer) ──────────────────────────────────────────────────────
WATCHVAULT_API_KEY=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# Audit log HMAC signing key (32+ bytes, cryptographically random).
# Once set, NEVER ROTATE — rotating breaks the audit chain verification.
# When empty, audit records have integrity hashes but no HMAC signature.
AUDIT_SIGNING_KEY=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=watchtower
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
POSTGRES_DB=watchtower

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Flask session secret — used to sign session cookies
DASHBOARD_SECRET_KEY=CHANGE_ME_GENERATE_LONG_RANDOM_STRING

# Default admin accounts (created on first start)
# CHANGE THESE IMMEDIATELY AFTER FIRST LOGIN
DASHBOARD_SUPER_ADMIN_USER=superadmin
DASHBOARD_SUPER_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ── Tips for generating secrets ───────────────────────────────────────────────
# Generate a strong random secret on Linux/Mac:
#   openssl rand -base64 32
# Or on any system with Python:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
